#!/usr/bin/env bash
set -euo pipefail

SOURCED=0
if [ "${BASH_SOURCE[0]}" != "$0" ]; then
  SOURCED=1
fi

finish() {
  local status="${1:-0}"

  if [ "$SOURCED" -eq 1 ]; then
    return "$status"
  fi

  exit "$status"
}

usage() {
  cat <<'EOF'
Usage: wt <path> <branch-name> [base-branch]
       wt -s <branch-name>
       wt --short <branch-name>
       wt -p [base-branch] [--dry-run] [--force-dirty]
       wt --prune [base-branch] [--dry-run] [--force-dirty]
       wt -d [branch-name|path] [--force-dirty]
       wt -D [branch-name|path] [--force-dirty]
       wt --delete [branch-name|path] [--force-dirty]

Create a git worktree for a new branch, then copy any paths listed in
.git-worktree-copy from the source repository into the new worktree.

Examples:
  wt ../my-feature feature/api-cleanup
  wt ../my-feature feature/api-cleanup main
  wt -s feature/api-cleanup
  wt --prune
  wt --prune main
  wt --prune main --dry-run
  wt --prune main --force-dirty
  wt --delete
  wt -D alak/web-call-info
  wt --delete alak/web-call-info

Interactive behavior:
  When run in a terminal, wt opens a shell in the new worktree directory.
EOF
}

SHORT_MODE=0
PRUNE_MODE=0
DELETE_MODE=0
DRY_RUN=0
FORCE_DIRTY=0

POSITIONAL_ARGS=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    -h|--help)
      usage
      finish 0
      ;;
    -s|--short)
      SHORT_MODE=1
      shift
      ;;
    -p|--prune)
      PRUNE_MODE=1
      shift
      ;;
    -d|-D|--delete)
      DELETE_MODE=1
      shift
      ;;
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    --force-dirty)
      FORCE_DIRTY=1
      shift
      ;;
    --)
      shift
      while [ "$#" -gt 0 ]; do
        POSITIONAL_ARGS+=("$1")
        shift
      done
      ;;
    -*)
      echo "Error: unknown option: $1" >&2
      usage
      finish 1
      ;;
    *)
      POSITIONAL_ARGS+=("$1")
      shift
      ;;
  esac
done

if [ "${#POSITIONAL_ARGS[@]}" -gt 0 ]; then
  set -- "${POSITIONAL_ARGS[@]}"
else
  set --
fi

ROOT="$(git rev-parse --show-toplevel)"
COPY_LIST="$ROOT/.git-worktree-copy"

delete_worktree() {
  local target="${1:-}"
  local force_dirty="${2:-0}"
  local current_pwd
  local cursor=""
  local delete_branch=""
  local delete_path=""
  local dirty_state=""
  local is_current="0"
  local is_dirty="0"
  local key=""
  local list_index=0
  local list_size=0
  local marker=""
  local move_up=""
  local read_status=0
  local idx=1
  local root_abs
  local branch_name
  local worktree_path
  local status_label=""
  local confirm
  local -a worktree_branches=()
  local -a worktree_paths=()
  local -a worktree_statuses=()

  root_abs="$(cd "$ROOT" && pwd)"
  current_pwd="$(pwd -P)"

  while IFS=$'\t' read -r branch_name worktree_path; do
    [ -z "$branch_name" ] && continue
    [ "$worktree_path" = "$root_abs" ] && continue

    if [ -n "$target" ]; then
      if [ "$target" = "$branch_name" ] || [ "$target" = "$worktree_path" ]; then
        delete_branch="$branch_name"
        delete_path="$worktree_path"
        break
      fi
    else
      if [ -n "$(git -C "$worktree_path" status --porcelain 2>/dev/null)" ]; then
        status_label="dirty"
      else
        status_label="clean"
      fi

      if [ "$current_pwd" = "$worktree_path" ]; then
        status_label="$status_label, current"
      fi

      worktree_branches+=("$branch_name")
      worktree_paths+=("$worktree_path")
      worktree_statuses+=("$status_label")
      idx=$((idx + 1))
    fi
  done < <(
    git -C "$ROOT" worktree list --porcelain | awk '
      /^worktree / { wt = substr($0, 10) }
      /^branch refs\/heads\// { print substr($0, 19) "\t" wt }
    '
  )

  if [ -z "$target" ]; then
    if [ "${#worktree_branches[@]}" -eq 0 ]; then
      echo "No linked worktrees available to delete."
      finish 0
    fi

    if ! [ -t 0 ] || ! [ -t 1 ]; then
      echo "Error: wt --delete requires a TTY when no branch or path is provided." >&2
      finish 1
    fi

    list_size="${#worktree_branches[@]}"
    printf 'Use arrow keys to choose a worktree, then press Enter.\n\n'
    cursor=0

    while true; do
      for ((idx = 0; idx < list_size; idx++)); do
        if [ "$idx" -eq "$cursor" ]; then
          marker="> "
        else
          marker="  "
        fi

        printf '%s%s -> %s [%s]\n' \
          "$marker" \
          "${worktree_branches[$idx]}" \
          "${worktree_paths[$idx]}" \
          "${worktree_statuses[$idx]}"
      done

      read_status=0
      IFS= read -rsn1 key || read_status=$?

      if [ "${read_status:-0}" -ne 0 ]; then
        echo
        finish 1
      fi

      case "$key" in
        "")
          delete_branch="${worktree_branches[$cursor]}"
          delete_path="${worktree_paths[$cursor]}"
          break
          ;;
        $'\x1b')
          IFS= read -rsn2 key || true
          case "$key" in
            '[A')
              if [ "$cursor" -gt 0 ]; then
                cursor=$((cursor - 1))
              else
                cursor=$((list_size - 1))
              fi
              ;;
            '[B')
              if [ "$cursor" -lt $((list_size - 1)) ]; then
                cursor=$((cursor + 1))
              else
                cursor=0
              fi
              ;;
            *)
              ;;
          esac
          ;;
        q|Q)
          echo
          echo "Cancelled."
          finish 0
          ;;
        *)
          ;;
      esac

      move_up=$((list_size))
      printf '\033[%sA' "$move_up"
      printf '\033[J'
    done

    printf '\033[%sA' "$list_size"
    printf '\033[J'
    printf 'Selected: %s -> %s [%s]\n' \
      "$delete_branch" \
      "$delete_path" \
      "${worktree_statuses[$cursor]}"
  fi

  if [ -z "$delete_branch" ] || [ -z "$delete_path" ]; then
    echo "Error: worktree not found: ${target:-selection}" >&2
    finish 1
  fi

  if [ "$delete_path" = "$root_abs" ]; then
    echo "Error: refusing to delete the main repository worktree." >&2
    finish 1
  fi

  if [ "$current_pwd" = "$delete_path" ]; then
    is_current="1"
  fi

  if [ -n "$(git -C "$delete_path" status --porcelain 2>/dev/null)" ]; then
    is_dirty="1"
  fi

  if [ "$is_current" = "1" ]; then
    echo "Error: refusing to delete the current worktree: $delete_path" >&2
    finish 1
  fi

  if [ "$is_dirty" = "1" ] && [ "$force_dirty" -ne 1 ]; then
    echo "Error: worktree is dirty: $delete_path" >&2
    echo "Re-run with --force-dirty to discard local changes." >&2
    finish 1
  fi

  if [ -t 0 ] && [ -t 1 ]; then
    printf 'Delete worktree %s (%s)? [y/N]: ' "$delete_branch" "$delete_path"
    read -r confirm

    case "$confirm" in
      y|Y|yes|YES)
        ;;
      *)
        echo "Cancelled."
        finish 0
        ;;
    esac
  fi

  if [ "$is_dirty" = "1" ] && [ "$force_dirty" -eq 1 ]; then
    git -C "$ROOT" worktree remove --force "$delete_path"
    git -C "$ROOT" branch -D "$delete_branch"
    echo "Removed dirty worktree: $delete_path ($delete_branch)"
  else
    git -C "$ROOT" worktree remove "$delete_path"
    git -C "$ROOT" branch -D "$delete_branch"
    echo "Removed worktree: $delete_path ($delete_branch)"
  fi

  finish 0
}

prune_worktrees() {
  local base_branch="${1:-main}"
  local dry_run="${2:-0}"
  local force_dirty="${3:-0}"
  local current_pwd
  local current_branch=""
  local merged_reason=""
  local remove_args=()
  local removed_count=0
  local skipped_count=0
  local worktree_path
  local branch_name
  local porcelain
  local cherry_output
  local root_abs

  git -C "$ROOT" rev-parse --verify --quiet "$base_branch^{commit}" >/dev/null || {
    echo "Error: base branch or commit not found: $base_branch" >&2
    finish 1
  }

  root_abs="$(cd "$ROOT" && pwd)"
  current_pwd="$(pwd -P)"
  current_branch="$(git -C "$ROOT" branch --show-current 2>/dev/null || true)"

  while IFS= read -r porcelain; do
    case "$porcelain" in
      "worktree "*)
        worktree_path="${porcelain#worktree }"
        branch_name=""
        ;;
      "branch refs/heads/"*)
        branch_name="${porcelain#branch refs/heads/}"

        [ "$worktree_path" = "$root_abs" ] && continue
        [ -z "$branch_name" ] && continue
        [ "$branch_name" = "$base_branch" ] && continue

        if [ "$current_pwd" = "$worktree_path" ]; then
          echo "Skipped current directory worktree: $worktree_path"
          skipped_count=$((skipped_count + 1))
          continue
        fi

        if [ -n "$current_branch" ] && [ "$branch_name" = "$current_branch" ]; then
          echo "Skipped current branch worktree: $branch_name"
          skipped_count=$((skipped_count + 1))
          continue
        fi

        merged_reason=""

        if git -C "$ROOT" merge-base --is-ancestor "$branch_name" "$base_branch"; then
          merged_reason="ancestor"
        else
          cherry_output="$(git -C "$ROOT" cherry "$base_branch" "$branch_name" 2>/dev/null || true)"

          if [ -z "$(printf '%s\n' "$cherry_output" | sed '/^-/d;/^$/d')" ]; then
            merged_reason="patch-equivalent"
          fi
        fi

        if [ -z "$merged_reason" ]; then
          echo "Skipped unmerged branch: $branch_name"
          skipped_count=$((skipped_count + 1))
          continue
        fi

        if [ -n "$(git -C "$worktree_path" status --porcelain 2>/dev/null)" ]; then
          if [ "$force_dirty" -eq 1 ]; then
            remove_args=(--force)
          else
            echo "Skipped dirty worktree: $worktree_path"
            skipped_count=$((skipped_count + 1))
            continue
          fi
        else
          remove_args=()
        fi

        if [ "$dry_run" -eq 1 ]; then
          if [ "$force_dirty" -eq 1 ] && [ "${#remove_args[@]}" -gt 0 ]; then
            echo "Would remove dirty merged worktree: $worktree_path ($branch_name, $merged_reason, forced)"
          else
            echo "Would remove merged worktree: $worktree_path ($branch_name, $merged_reason)"
          fi
        else
          git -C "$ROOT" worktree remove "${remove_args[@]}" "$worktree_path"
          git -C "$ROOT" branch -d "$branch_name"
          if [ "$force_dirty" -eq 1 ] && [ "${#remove_args[@]}" -gt 0 ]; then
            echo "Removed dirty merged worktree: $worktree_path ($branch_name, $merged_reason, forced)"
          else
            echo "Removed merged worktree: $worktree_path ($branch_name, $merged_reason)"
          fi
        fi
        removed_count=$((removed_count + 1))
        ;;
    esac
  done < <(git -C "$ROOT" worktree list --porcelain)

  if [ "$dry_run" -eq 1 ]; then
    echo "Would run: git worktree prune"
  else
    git -C "$ROOT" worktree prune
  fi

  echo
  if [ "$dry_run" -eq 1 ]; then
    echo "Dry run complete:"
  else
    echo "Prune complete:"
  fi
  echo "  base:    $base_branch"
  echo "  removed: $removed_count"
  echo "  skipped: $skipped_count"

  finish 0
}

if [ "$PRUNE_MODE" -eq 1 ]; then
  if [ "$SHORT_MODE" -eq 1 ] || [ "$DELETE_MODE" -eq 1 ] || [ "$#" -gt 2 ]; then
    usage
    finish 1
  fi

  prune_worktrees "${1:-main}" "$DRY_RUN" "$FORCE_DIRTY"
fi

if [ "$DELETE_MODE" -eq 1 ]; then
  if [ "$SHORT_MODE" -eq 1 ] || [ "$PRUNE_MODE" -eq 1 ] || [ "$DRY_RUN" -eq 1 ] || [ "$#" -gt 1 ]; then
    usage
    finish 1
  fi

  delete_worktree "${1:-}" "$FORCE_DIRTY"
fi

if [ "$SHORT_MODE" -eq 1 ]; then
  if [ "$#" -ne 1 ]; then
    usage
    finish 1
  fi

  BRANCH_NAME="$1"
  WORKTREE_PATH="../$BRANCH_NAME"
  BASE_BRANCH="main"
else
  if [ "$DRY_RUN" -eq 1 ] || [ "$FORCE_DIRTY" -eq 1 ]; then
    usage
    finish 1
  fi

  if [ "$#" -lt 2 ] || [ "$#" -gt 3 ]; then
    usage
    finish 1
  fi

  WORKTREE_PATH="$1"
  BRANCH_NAME="$2"
  BASE_BRANCH="${3:-HEAD}"
fi

if [ -e "$WORKTREE_PATH" ]; then
  echo "Error: destination already exists: $WORKTREE_PATH" >&2
  finish 1
fi

if git -C "$ROOT" rev-parse --verify --quiet "$BRANCH_NAME" >/dev/null; then
  echo "Error: branch already exists: $BRANCH_NAME" >&2
  finish 1
fi

git -C "$ROOT" rev-parse --verify --quiet "$BASE_BRANCH^{commit}" >/dev/null || {
  echo "Error: base branch or commit not found: $BASE_BRANCH" >&2
  finish 1
}

git -C "$ROOT" worktree add -b "$BRANCH_NAME" "$WORKTREE_PATH" "$BASE_BRANCH"

copied_count=0
skipped_count=0

if [ -f "$COPY_LIST" ]; then
  while IFS= read -r file || [ -n "$file" ]; do
    [ -z "$file" ] && continue
    [ "${file#\#}" != "$file" ] && continue

    SRC="$ROOT/$file"
    DEST="$WORKTREE_PATH/$file"

    if [ -e "$SRC" ]; then
      mkdir -p "$(dirname "$DEST")"
      cp -R "$SRC" "$DEST"
      copied_count=$((copied_count + 1))
      echo "Copied $file"
    else
      skipped_count=$((skipped_count + 1))
      echo "Skipped missing $file"
    fi
  done < "$COPY_LIST"
fi

WORKTREE_ABS="$(cd "$WORKTREE_PATH" && pwd)"

echo
echo "Created worktree:"
echo "  path:    $WORKTREE_ABS"
echo "  branch:  $BRANCH_NAME"
echo "  from:    $BASE_BRANCH"
echo "  copied:  $copied_count"
echo "  skipped: $skipped_count"

if [ "$SOURCED" -eq 1 ]; then
  cd "$WORKTREE_ABS"
  finish 0
fi

if [ -t 0 ] && [ -t 1 ]; then
  echo
  echo "Entering $WORKTREE_ABS"
  cd "$WORKTREE_ABS"
  exec "${SHELL:-/bin/bash}" -i
fi

echo
echo "Run this to enter the worktree:"
echo "  cd $WORKTREE_ABS"
